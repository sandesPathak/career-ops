{
  "name": "career-ops",
  "version": "1.0.0",
  "description": "AI-powered job search pipeline built on Claude Code",
  "scripts": {
    "doctor": "node doctor.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "scan": "node scan.mjs",
    "scan:aggregators": "node scan-aggregators.mjs",
    "scan:curated": "node scan-curated.mjs",
    "scan:himalayas": "node scan-himalayas.mjs",
    "scan:all": "node scan.mjs && node scan-aggregators.mjs && node scan-himalayas.mjs && node scan-curated.mjs && node scan-discover.mjs",
    "setup:python": "python3 -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install -r requirements.txt",
    "discover": "node scan-discover.mjs",
    "gemini:eval": "node gemini-eval.mjs",
    "ui": "node ui/server.mjs"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
  "author": "Sandesh Pathak <noreply@users.noreply.github.com> (https://github.com/sandesPathak)",
  "homepage": "https://github.com/sandesPathak",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandesPathak/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.1"
  }
}
